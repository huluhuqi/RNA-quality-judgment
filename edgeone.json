{
  "name": "RNA-quality-judgment",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "./dist",
  "nodeVersion": "20.18.0",
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "max-age=7200"
        }
      ]
    },
    {
      "source": "/assets/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=31536000"
        }
      ]
    }
  ]
}
